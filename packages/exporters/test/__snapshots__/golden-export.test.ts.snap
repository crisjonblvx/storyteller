    <asset id="r2" uid="asset-primary-001" name="interview-a-roll.mov" start="0s" duration="108000/30s" hasVideo="1" hasAudio="1" videoSources="1" audioSources="1" audioChannels="2" audioRate="48000" format="r1">
      <media-rep kind="original-media" src="file:///Volumes/Media/interview-a-roll.mov" />
    </asset>
  </resources>
  <library>
    <event name="B-Roll">
      <clip name="interview-a-roll.mov">
        <video>
          <asset-clip ref="r2" offset="0s" name="interview-a-roll.mov" duration="108000/30s" start="0s"/>
        </video>
      </clip>
    </event>
    <event name="Storyteller Export">
      <project name="seq-proj-interview">
        <sequence duration="990/30s" format="r1" tcStart="0s" tcFormat="NDF">
          <spine>
          <asset-clip name="interview-a-roll.mov" ref="r2" offset="0/30s" duration="330/30s" start="360/30s" enabled="1" tcFormat="NDF"/>
          <asset-clip name="interview-a-roll.mov" ref="r2" offset="330/30s" duration="330/30s" start="1350/30s" enabled="1" tcFormat="NDF"/>
          <asset-clip name="interview-a-roll.mov" ref="r2" offset="660/30s" duration="330/30s" start="3600/30s" enabled="1" tcFormat="NDF"/>
          </spine>
        </sequence>
      </project>
    </event>
  </library>
</fcpxml>"
`;

