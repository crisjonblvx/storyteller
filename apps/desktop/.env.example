# Copy to apps/desktop/.env — Supabase (https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# After setting these, run supabase migrations (see docs/media-ingestion.md) and create/auth users.
# Storage bucket: project-media (created by migration).

# OpenAI — used by Electron main for Whisper transcription (not VITE_ — keep out of renderer bundle)
OPENAI_API_KEY=
