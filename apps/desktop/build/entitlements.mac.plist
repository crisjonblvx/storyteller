<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron's JIT/V8 engine -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Required for Electron renderer process -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Required for ffmpeg and native modules that load dynamic libraries -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Outbound network for API calls (OpenAI, Supabase, AI gateway) -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Local server for embedded AI gateway process -->
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- Read/write access to user-selected files (project imports/exports) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- Downloads folder access for exported videos -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>
</dict>
</plist>
