# Optional: override redirect URLs (default uses storyteller:// deep links for the desktop app)
# STRIPE_BILLING_SUCCESS_URL=storyteller://billing/success?session_id={CHECKOUT_SESSION_ID}
# STRIPE_BILLING_CANCEL_URL=storyteller://billing/cancel

# Admin dashboard (server-only — never expose via VITE_*)
STORYTELLER_ADMIN_PASSWORD=

# Optional internal/founder owner-plan overrides (comma-separated)
