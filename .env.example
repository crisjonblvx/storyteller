# Desktop — local development
STORYTELLER_AI_MODE=local
STORYTELLER_GATEWAY_URL=http://localhost:8787
# Spawn apps/ai-gateway automatically when Storyteller starts (dev default).
# Set false to run `npm run gateway:dev` yourself or use a remote gateway URL.
STORYTELLER_EMBED_GATEWAY=
STORYTELLER_PROXY_TOKEN=

# Optional direct provider keys (dev only — not for end users)
OPENAI_API_KEY=
RUNWAY_API_KEY=
KLING_API_KEY=
GROK_API_KEY=
GROK_API_MODEL=grok-imagine-video-1.5
GEMINI_API_KEY=
GEMINI_VIDEO_MODEL=veo-3.1-generate-preview
ENABLE_LEGACY_VIDEO_PROVIDERS=false

# Optional: choose the OpenAI model used for transcript/soundbite review
STORYTELLER_REVIEW_MODEL=gpt-5.4-mini

# Optional: OpenAI image generation model (still frames)
OPENAI_IMAGE_MODEL=gpt-image-2

ENABLE_BYOK=false
ENABLE_KLING=false

# Renderer (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# VITE_AUDIO_DIRECTOR_ENABLED=true
